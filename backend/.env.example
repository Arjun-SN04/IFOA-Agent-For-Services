# Copy this to .env for local development
# In Render dashboard, add ALL of these as Environment Variables

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agentDB?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret

# Your Vercel frontend URL — no trailing slash
FRONTEND_URL=https://your-app.vercel.app

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Use sk_test_... for test mode, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
# Get this from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# ── Optional ───────────────────────────────────────────────────────────────────
GROQ_API=replace_with_groq_api_key
