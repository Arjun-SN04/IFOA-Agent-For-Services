# ── React SPA (Vite) — Apache / cPanel ──────────────────────────────────────
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # All other routes → index.html (client-side routing)
  RewriteRule ^ index.html [L]
</IfModule>

# ── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/font-woff2
</IfModule>

# ── Caching ─────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed assets (JS/CSS/images/fonts) — cache long, they are content-hashed
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  # HTML must always revalidate so new deploys are picked up
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Never cache index.html — guarantees users get the latest build
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
